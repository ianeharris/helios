# Copy to .env and fill in values before running docker compose up.
# The actual .env is never committed - secrets come from SOPS at deploy time.

HELIOS_VERSION=latest

# Populated by the deploy script from SOPS-decrypted secrets.
# Do not set manually in production - set by infra/scripts/deploy.sh
DB_PASSWORD=

# Phase 1+ - uncomment when the adapter is enabled in docker-compose.yml

# Hue - two Bridge v2 units. JSON array; IPs must have static DHCP reservations.
# HUE_BRIDGES=[{"id":"ECB5FAFFFE2CA569","ip":"192.168.86.199","name":"Bradgate"},{"id":"ECB5FAFFFEBE1854","ip":"192.168.86.248","name":"Bradgate 2"}]
# App keys are in SOPS secrets (hue_app_key_bradgate, hue_app_key_bradgate2)
# SONOS_DISCOVERY_TIMEOUT_MS=5000
# HIKVISION_NVR_IP=192.168.86.xxx
# HIKVISION_USERNAME=
# HIKVISION_PASSWORD=
# FOXESS_API_KEY=
# TEXECOM_IP=192.168.86.xxx
# TEXECOM_UDL_PASSCODE=
# HIVE_USERNAME=
# HIVE_PASSWORD=
