helios.lan, helios.ian, m1-mac-mini.tailfc238d.ts.net {
    tls internal

    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
        Permissions-Policy "camera=(), microphone=(), geolocation=()"
        Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; font-src 'self' data:; connect-src 'self'"
    }

    # Authelia portal, static assets, and its own API — bypass forward_auth
    handle /auth* {
        reverse_proxy authelia:9091
    }

    # Authelia's password-reset page must also be reachable before login.
    handle /reset-password* {
        reverse_proxy authelia:9091
    }
    handle /static/* {
        reverse_proxy authelia:9091
    }
    handle /locales* {
        reverse_proxy authelia:9091
    }
    handle /api/configuration/* {
        reverse_proxy authelia:9091
    }
    handle /api/verify* {
        reverse_proxy authelia:9091
    }
    handle /api/state {
        reverse_proxy authelia:9091
    }
    handle /api/firstfactor {
        reverse_proxy authelia:9091
    }
    handle /api/secondfactor/* {
        reverse_proxy authelia:9091
    }
    handle /api/user/* {
        reverse_proxy authelia:9091
    }
    handle /api/logout {
        reverse_proxy authelia:9091
    }
    handle /api/reset-password* {
        reverse_proxy authelia:9091
    }
    handle /api/oidc/* {
        reverse_proxy authelia:9091
    }
    handle /locales/* {
        reverse_proxy authelia:9091
    }

    # Health probe and PWA manifest — no auth required
    handle /health {
        reverse_proxy api:3000
    }
    handle /manifest.json {
        reverse_proxy web:80
    }
    handle /favicon.ico {
        reverse_proxy web:80
    }

    # Everything else requires authentication
    handle {
        forward_auth authelia:9091 {
            uri /api/verify?rd=https://{host}/auth
            copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
        }

        handle /api/* {
            uri strip_prefix /api
            reverse_proxy api:3000
        }

        handle /grafana/* {
            reverse_proxy grafana:3000
        }

        handle {
            reverse_proxy web:80
        }
    }
}
