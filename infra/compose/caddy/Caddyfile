helios.lan {
    tls internal

    # Forward auth to Authelia for every request
    forward_auth authelia:9091 {
        uri /api/verify?rd=https://helios.lan/auth
        copy_headers Remote-User Remote-Groups Remote-Name Remote-Email
    }

    # API — strip /api prefix so routes don't need to know they're mounted there
    handle /api/* {
        uri strip_prefix /api
        reverse_proxy api:3000
    }

    # Grafana
    handle /grafana/* {
        reverse_proxy grafana:3000
    }

    # Authelia login portal
    handle /auth* {
        reverse_proxy authelia:9091
    }

    # Health probe (no auth required)
    handle /health {
        reverse_proxy api:3000
    }

    # PWA frontend — catch-all so React Router handles all paths
    handle {
        reverse_proxy web:80
    }
}
