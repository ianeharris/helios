# Helios MQTT ACL
# Format: user <username> / topic <access> <topic>
# access: read=1, write=2, readwrite=4

user octopus
topic write helios/energy/#
topic write helios/registry/octopus/#

user hue
topic readwrite helios/hue/#
topic write helios/registry/hue/#

user sonos
topic write helios/audio/#
topic read helios/audio/+/command
topic write helios/registry/sonos/#

user api
topic read helios/#
topic write helios/hue/#
topic write helios/audio/#
topic write helios/heating/#
topic write helios/security/#

user foxess
topic write helios/energy/foxess/#
topic write helios/registry/foxess/#

user hikvision
topic write helios/security/cameras/#
topic write helios/registry/hikvision/#

user texecom
topic write helios/security/alarm/#
topic write helios/registry/texecom/#

user hive
topic write helios/heating/#
topic read helios/heating/+/set
topic write helios/registry/hive/#
