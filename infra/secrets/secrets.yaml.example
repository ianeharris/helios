# Template for infra/secrets/secrets.yaml
# Copy to secrets.yaml, fill in values, then encrypt with:
#   sops --encrypt --in-place secrets.yaml
# The encrypted file IS committed to git. The plaintext version never is.

db_password: "CHANGE_ME_strong_random_password"

authelia_jwt_secret: "CHANGE_ME_64_char_random_string"
authelia_session_secret: "CHANGE_ME_64_char_random_string"
authelia_storage_key: "CHANGE_ME_64_char_random_string"

grafana_admin_password: "CHANGE_ME"

